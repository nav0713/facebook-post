# ─────────────────────────────────────────────────────────
# Taglish News / News Post Recreator Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# Google Gemini API Key — used by News Post Recreator and existing news tools.
# Without this key, /api/generate returns a local placeholder.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Facebook Graph API — used by the existing Facebook posting feature.
# FACEBOOK_PAGE_ID    : numeric ID of the Facebook Page you manage
# FACEBOOK_PAGE_ACCESS_TOKEN : long-lived Page Access Token with pages_manage_posts permission
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
