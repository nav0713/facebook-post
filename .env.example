# ─────────────────────────────────────────────────────────
# Taglish News Extractor — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Facebook Graph API — required for "I-post sa Facebook" feature
# FACEBOOK_PAGE_ID    : numeric ID of the Facebook Page you manage
# FACEBOOK_PAGE_ACCESS_TOKEN : long-lived Page Access Token with pages_manage_posts permission
#   Generate via: Graph API Explorer → select your Page → add pages_manage_posts scope → Get Token
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
